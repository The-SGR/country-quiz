<resources>
    <style name="Base.Theme.CountryQuiz" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/dark_brown</item>
        <item name="android:fontFamily">@font/manrope</item>
        <item name="android:textFontWeight">900</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>

        <item name="materialButtonStyle">@style/defaultBtnStyle</item>
        <item name="materialSwitchStyle">@style/defaultSwitchStyle</item>
    </style>

    <style name="Amoled.Theme.CountryQuiz" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:fontFamily">@font/manrope</item>
        <item name="android:textFontWeight">900</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/mint</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="materialButtonStyle">@style/amoledBtnStyle</item>
        <item name="materialSwitchStyle">@style/amoledSwitchStyle</item>
    </style>

    <style name="Dark.Theme.CountryQuiz" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/dark_gray</item>

        <item name="materialButtonStyle">@style/darkBtnStyle</item>
        <item name="materialSwitchStyle">@style/defaultSwitchStyle</item>
    </style>

    <style name="Blue.Theme.CountryQuiz" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/navy_blue</item>

        <item name="materialButtonStyle">@style/blueBtnStyle</item>
        <item name="materialSwitchStyle">@style/defaultSwitchStyle</item>
    </style>
</resources>